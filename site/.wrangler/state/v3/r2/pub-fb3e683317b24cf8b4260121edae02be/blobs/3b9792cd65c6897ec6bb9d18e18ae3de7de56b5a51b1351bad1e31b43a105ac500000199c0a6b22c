<svg viewBox="0 0 1200 800" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="goldGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#FFD700;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#FFA500;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="blueGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#4A90E2;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#357ABD;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="greenGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#5CDB95;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#379683;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="purpleGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#9B59B6;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#8E44AD;stop-opacity:1" />
    </linearGradient>
    <filter id="shadow">
      <feDropShadow dx="2" dy="2" stdDeviation="3" flood-opacity="0.3"/>
    </filter>
  </defs>

  <!-- Title -->
  <text x="600" y="40" font-family="Arial, sans-serif" font-size="28" font-weight="bold" text-anchor="middle" fill="#2C3E50">
    Stablecoin Seigniorage: Private Profit from Public Money
  </text>

  <!-- Left side: Traditional Fed Seigniorage -->
  <g id="fed-model">
    <rect x="50" y="80" width="480" height="320" rx="10" fill="#F8F9FA" stroke="#2C3E50" stroke-width="2" filter="url(#shadow)"/>
    <text x="290" y="110" font-family="Arial, sans-serif" font-size="20" font-weight="bold" text-anchor="middle" fill="#2C3E50">
      Traditional Federal Reserve Model
    </text>

    <!-- Fed creates money -->
    <rect x="80" y="140" width="180" height="80" rx="8" fill="url(#blueGrad)" filter="url(#shadow)"/>
    <text x="170" y="170" font-family="Arial, sans-serif" font-size="14" font-weight="bold" text-anchor="middle" fill="white">
      Federal Reserve
    </text>
    <text x="170" y="190" font-family="Arial, sans-serif" font-size="12" text-anchor="middle" fill="white">
      Creates money via
    </text>
    <text x="170" y="206" font-family="Arial, sans-serif" font-size="12" text-anchor="middle" fill="white">
      QE, lending, bonds
    </text>

    <!-- Arrow down to interest -->
    <path d="M 170 220 L 170 260" stroke="#2C3E50" stroke-width="3" fill="none" marker-end="url(#arrowhead)"/>

    <!-- Interest earned -->
    <rect x="80" y="260" width="180" height="60" rx="8" fill="url(#goldGrad)" filter="url(#shadow)"/>
    <text x="170" y="285" font-family="Arial, sans-serif" font-size="14" font-weight="bold" text-anchor="middle" fill="#2C3E50">
      Seigniorage Profit
    </text>
    <text x="170" y="305" font-family="Arial, sans-serif" font-size="12" text-anchor="middle" fill="#2C3E50">
      ~$100B/year historically
    </text>

    <!-- Arrow to Treasury -->
    <path d="M 170 320 L 170 360" stroke="#2C3E50" stroke-width="3" fill="none" marker-end="url(#arrowhead)"/>

    <!-- Returns to Treasury -->
    <rect x="300" y="260" width="200" height="120" rx="8" fill="url(#greenGrad)" filter="url(#shadow)"/>
    <text x="400" y="290" font-family="Arial, sans-serif" font-size="14" font-weight="bold" text-anchor="middle" fill="white">
      U.S. Treasury
    </text>
    <text x="400" y="310" font-family="Arial, sans-serif" font-size="12" text-anchor="middle" fill="white">
      Receives profit
    </text>
    <text x="400" y="330" font-family="Arial, sans-serif" font-size="12" text-anchor="middle" fill="white">
      ↓
    </text>
    <text x="400" y="350" font-family="Arial, sans-serif" font-size="12" text-anchor="middle" fill="white">
      Returns to taxpayers
    </text>
    <text x="400" y="365" font-family="Arial, sans-serif" font-size="12" text-anchor="middle" fill="white">
      via services/programs
    </text>

    <!-- Arrow connecting Fed to Treasury -->
    <path d="M 260 290 L 300 290" stroke="#2C3E50" stroke-width="3" fill="none" marker-end="url(#arrowhead)"/>
  </g>

  <!-- Right side: Stablecoin Seigniorage -->
  <g id="stablecoin-model">
    <rect x="670" y="80" width="480" height="320" rx="10" fill="#FFF5F5" stroke="#E74C3C" stroke-width="2" filter="url(#shadow)"/>
    <text x="910" y="110" font-family="Arial, sans-serif" font-size="20" font-weight="bold" text-anchor="middle" fill="#2C3E50">
      Private Stablecoin Model (USDT/USDC)
    </text>

    <!-- Stablecoin issuer -->
    <rect x="700" y="140" width="180" height="80" rx="8" fill="url(#purpleGrad)" filter="url(#shadow)"/>
    <text x="790" y="165" font-family="Arial, sans-serif" font-size="14" font-weight="bold" text-anchor="middle" fill="white">
      Private Company
    </text>
    <text x="790" y="185" font-family="Arial, sans-serif" font-size="12" text-anchor="middle" fill="white">
      (Circle, Tether)
    </text>
    <text x="790" y="205" font-family="Arial, sans-serif" font-size="12" text-anchor="middle" fill="white">
      Mints $1 stablecoin
    </text>

    <!-- User gives $1 -->
    <rect x="920" y="150" width="200" height="60" rx="8" fill="#ECF0F1" stroke="#2C3E50" stroke-width="2"/>
    <text x="1020" y="175" font-family="Arial, sans-serif" font-size="12" font-weight="bold" text-anchor="middle" fill="#2C3E50">
      User deposits $1
    </text>
    <text x="1020" y="195" font-family="Arial, sans-serif" font-size="11" text-anchor="middle" fill="#7F8C8D">
      Receives 1 USDT/USDC
    </text>

    <!-- Arrow: company holds reserves -->
    <path d="M 790 220 L 790 260" stroke="#2C3E50" stroke-width="3" fill="none" marker-end="url(#arrowhead)"/>

    <!-- T-Bills -->
    <rect x="700" y="260" width="180" height="60" rx="8" fill="url(#goldGrad)" filter="url(#shadow)"/>
    <text x="790" y="280" font-family="Arial, sans-serif" font-size="13" font-weight="bold" text-anchor="middle" fill="#2C3E50">
      Buys T-Bills
    </text>
    <text x="790" y="300" font-family="Arial, sans-serif" font-size="12" text-anchor="middle" fill="#2C3E50">
      $200B+ at 5% = $10B/yr
    </text>

    <!-- Arrow to private profit -->
    <path d="M 790 320 L 790 360" stroke="#2C3E50" stroke-width="3" fill="none" marker-end="url(#arrowhead)"/>

    <!-- Private profit -->
    <rect x="700" y="360" width="420" height="80" rx="8" fill="#E74C3C" filter="url(#shadow)"/>
    <text x="910" y="385" font-family="Arial, sans-serif" font-size="16" font-weight="bold" text-anchor="middle" fill="white">
      🚨 PRIVATE COMPANIES KEEP ALL INTEREST 🚨
    </text>
    <text x="910" y="410" font-family="Arial, sans-serif" font-size="13" text-anchor="middle" fill="white">
      $10B+/year profit ⚠ Pays 0% to token holders ⚠ No taxpayer benefit
    </text>
    <text x="910" y="428" font-family="Arial, sans-serif" font-size="11" text-anchor="middle" fill="white">
      (Seigniorage that would historically go to U.S. Treasury now goes to Circle/Tether shareholders)
    </text>
  </g>

  <!-- Bottom: Market Impact -->
  <rect x="50" y="450" width="1100" height="320" rx="10" fill="#EBF5FB" stroke="#2C3E50" stroke-width="2" filter="url(#shadow)"/>
  <text x="600" y="480" font-family="Arial, sans-serif" font-size="20" font-weight="bold" text-anchor="middle" fill="#2C3E50">
    Stablecoin Market Impact &amp; UBI Implications
  </text>

  <!-- Left column: Market Stats -->
  <g id="market-stats">
    <text x="80" y="520" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#2C3E50">
      📊 Market Size (2025)
    </text>
    <text x="80" y="545" font-family="Arial, sans-serif" font-size="12" fill="#34495E">
      • Total stablecoin market cap: <tspan font-weight="bold">$251B</tspan> (Q2) → <tspan font-weight="bold">$300B</tspan> (Q3)
    </text>
    <text x="80" y="565" font-family="Arial, sans-serif" font-size="12" fill="#34495E">
      • USDT market share: <tspan font-weight="bold">59-64%</tspan> ($140-146B)
    </text>
    <text x="80" y="585" font-family="Arial, sans-serif" font-size="12" fill="#34495E">
      • USDC market share: <tspan font-weight="bold">24-25%</tspan> ($56-60B)
    </text>
    <text x="80" y="605" font-family="Arial, sans-serif" font-size="12" fill="#34495E">
      • Trading volume Q3 2025: <tspan font-weight="bold">$10.3 trillion</tspan>
    </text>
    <text x="80" y="625" font-family="Arial, sans-serif" font-size="12" fill="#34495E">
      • Annual transfer volume: <tspan font-weight="bold">$27.6T</tspan> (exceeds Visa+Mastercard)
    </text>

    <text x="80" y="660" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#2C3E50">
      🌍 Crypto Economy Impact
    </text>
    <text x="80" y="685" font-family="Arial, sans-serif" font-size="12" fill="#34495E">
      • <tspan font-weight="bold">80%+</tspan> of exchange trades involve stablecoin pairs
    </text>
    <text x="80" y="705" font-family="Arial, sans-serif" font-size="12" fill="#34495E">
      • <tspan font-weight="bold">60%</tspan> of stablecoin inflows → crypto purchases within 72hrs
    </text>
    <text x="80" y="725" font-family="Arial, sans-serif" font-size="12" fill="#34495E">
      • Tightest spreads: <tspan font-weight="bold">&lt;0.01%</tspan> (liquidity backbone)
    </text>
  </g>

  <!-- Right column: UBI Opportunity -->
  <g id="ubi-opportunity">
    <text x="650" y="520" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#E74C3C">
      💡 UBI Funding Opportunity
    </text>
    <text x="650" y="545" font-family="Arial, sans-serif" font-size="12" fill="#34495E">
      <tspan font-weight="bold">Current Reality (GENIUS Act 2025):</tspan>
    </text>
    <text x="650" y="565" font-family="Arial, sans-serif" font-size="12" fill="#34495E">
      ✗ Government-issued stablecoins <tspan font-weight="bold" fill="#E74C3C">PROHIBITED</tspan>
    </text>
    <text x="650" y="585" font-family="Arial, sans-serif" font-size="12" fill="#34495E">
      ✗ Private companies capture $10B+/year seigniorage
    </text>
    <text x="650" y="605" font-family="Arial, sans-serif" font-size="12" fill="#34495E">
      ✗ Zero interest paid to token holders (pure profit)
    </text>

    <text x="650" y="635" font-family="Arial, sans-serif" font-size="12" fill="#34495E">
      <tspan font-weight="bold">Alternative UBI Model:</tspan>
    </text>
    <text x="650" y="655" font-family="Arial, sans-serif" font-size="12" fill="#27AE60">
      ✓ Tax stablecoin seigniorage at <tspan font-weight="bold">50%</tspan> → $5B/year for UBI
    </text>
    <text x="650" y="675" font-family="Arial, sans-serif" font-size="12" fill="#27AE60">
      ✓ Government-backed UBI stablecoin (repeal prohibition)
    </text>
    <text x="650" y="695" font-family="Arial, sans-serif" font-size="12" fill="#27AE60">
      ✓ Seigniorage funds UBI directly ($10B+/year at scale)
    </text>
    <text x="650" y="715" font-family="Arial, sans-serif" font-size="12" fill="#27AE60">
      ✓ By 2030: Stablecoins may <tspan font-weight="bold">replace China/Japan</tspan> as
    </text>
    <text x="670" y="730" font-family="Arial, sans-serif" font-size="12" fill="#27AE60">
      top Treasury holders → $20B+ seigniorage potential
    </text>
  </g>

  <!-- Arrow markers -->
  <defs>
    <marker id="arrowhead" markerWidth="10" markerHeight="10" refX="9" refY="3" orient="auto">
      <polygon points="0 0, 10 3, 0 6" fill="#2C3E50" />
    </marker>
  </defs>
</svg>