{
  "name": "new-divinci-zola-site",
  "version": "1.0.0",
  "description": "New Divinci AI Zola Site",
  "scripts": {
    "build": "zola build",
    "serve": "zola serve --port 1111",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:visual": "playwright test --project=Visual-Desktop-Chrome --project=Visual-Mobile-Chrome tests/new-divinci-visual.spec.js",
    "test:visual:comprehensive": "node scripts/visual-test-runner.js visual-comprehensive",
    "test:visual:cross-browser": "node scripts/visual-test-runner.js visual-cross-browser",
    "test:visual:mobile": "node scripts/visual-test-runner.js visual-mobile",
    "test:visual:performance": "node scripts/visual-test-runner.js visual-performance",
    "test:visual:multilingual": "node scripts/visual-test-runner.js visual-multilingual",
    "test:visual:accessibility": "node scripts/visual-test-runner.js visual-accessibility",
    "test:visual:responsive": "node scripts/visual-test-runner.js visual-responsive",
    "test:visual:all": "node scripts/visual-test-runner.js visual-all",
    "test:visual:update": "playwright test --project=Visual-Desktop-Chrome --project=Visual-Mobile-Chrome tests/new-divinci-visual.spec.js --update-snapshots",
    "test:e2e": "playwright test --config=playwright.config.js --project=Desktop-Chrome --project=Mobile-Chrome",
    "test:report": "playwright show-report",
    "test:debug": "playwright test --debug",
    "test:accessibility": "playwright test tests/accessibility*.spec.js",
    "test:a11y": "playwright test tests/accessibility*.spec.js --headed",
    "test:a11y:report": "playwright test tests/accessibility*.spec.js --reporter=html --output-dir=accessibility-report",
    "test:a11y:config": "playwright test --config=accessibility.config.js",
    "test:a11y:visual": "playwright test tests/accessibility-visual.spec.js",
    "test:a11y:i18n": "playwright test tests/accessibility-i18n.spec.js",
    "test:a11y:keyboard": "playwright test tests/accessibility.spec.js --grep='Keyboard'",
    "test:a11y:contrast": "playwright test tests/accessibility-visual.spec.js --grep='Color Contrast'",
    "test:all-langs": "playwright test tests/accessibility-i18n.spec.js",
    "test:compare": "playwright test tests-new/e2e/site-comparison.test.js",
    "test:compare:report": "playwright test tests-new/e2e/site-comparison.test.js --reporter=html --output-dir=comparison-report",
    "test:comprehensive": "playwright test comprehensive-site-navigation.spec.js form-functionality.spec.js responsive-mobile.spec.js interactive-animations.spec.js performance-assets.spec.js",
    "test:navigation": "playwright test comprehensive-site-navigation.spec.js",
    "test:forms": "playwright test form-functionality.spec.js",
    "test:responsive": "playwright test responsive-mobile.spec.js",
    "test:interactions": "playwright test interactive-animations.spec.js",
    "test:performance": "playwright test performance-assets.spec.js",
    "test:visual:new": "playwright test visual-regression.spec.js",
    "test:full-suite": "playwright test --config=playwright.config.js --project=Desktop-Chrome --project=Mobile-Chrome --project=Visual-Desktop",
    "test:lang-nav": "playwright test language-navigation-comprehensive.spec.js",
    "test:lang-nav:headed": "playwright test language-navigation-comprehensive.spec.js --headed",
    "test:lang-switcher": "playwright test language-switcher-e2e.spec.js",
    "test:lang-switcher:headed": "playwright test language-switcher-e2e.spec.js --headed",
    "test:video": "playwright test video-functionality.spec.js",
    "test:video:headed": "playwright test video-functionality.spec.js --headed",
    "test:layout": "playwright test layout-alignment.spec.js",
    "test:layout:headed": "playwright test layout-alignment.spec.js --headed",
    "test:journal": "playwright test journal-functionality.spec.js",
    "test:journal:headed": "playwright test journal-functionality.spec.js --headed",
    "test:footer-nav": "playwright test footer-language-navigation.spec.js",
    "test:footer-nav:headed": "playwright test footer-language-navigation.spec.js --headed",
    "test:new-features": "playwright test video-functionality.spec.js layout-alignment.spec.js journal-functionality.spec.js footer-language-navigation.spec.js",
    "test:core": "playwright test new-divinci-site.spec.js language-health-check.spec.js",
    "test:mobile": "playwright test --config=playwright.config.js --project=Mobile-Chrome --project=Mobile-Safari",
    "test:mobile:visual": "playwright test --config=playwright.config.js --project=Visual-Mobile comprehensive-mobile-visual.spec.js",
    "test:mobile:comprehensive": "playwright test comprehensive-mobile-visual.spec.js mobile-navigation-comprehensive.spec.js responsive-mobile.spec.js",
    "test:mobile:navigation": "playwright test mobile-navigation-comprehensive.spec.js",
    "test:mobile:devices": "playwright test --config=playwright.config.js --project=Mobile-Multi-Device",
    "test:mobile:all": "playwright test --config=playwright.config.js --project=Mobile-Chrome --project=Mobile-Safari --project=Visual-Mobile --project=Mobile-Multi-Device",
    "test:mobile:suite": "playwright test tests/mobile-comprehensive-suite.spec.js --reporter=list",
    "test:mobile:suite:headed": "playwright test tests/mobile-comprehensive-suite.spec.js --headed",
    "test:mobile:navigation:comprehensive": "playwright test tests/comprehensive-mobile-navigation.spec.js --reporter=list",
    "test:mobile:language:comprehensive": "playwright test tests/comprehensive-mobile-language.spec.js --reporter=list",
    "test:mobile:journeys": "playwright test tests/comprehensive-mobile-journeys.spec.js --reporter=list",
    "test:mobile:performance:comprehensive": "playwright test tests/comprehensive-mobile-performance.spec.js --reporter=list",
    "test:mobile:full": "playwright test tests/comprehensive-mobile-*.spec.js --reporter=list",
    "test:unit": "playwright test --config=unit-tests.config.js",
    "test:unit:headed": "playwright test --config=unit-tests.config.js --headed",
    "test:validate": "node tests/unit/test-suite-validator.js",
    "test:health": "npm run test:unit && npm run test:validate",
    "test:all": "npm run test:unit && npm run test:validate && npm run test",
    "pre-deploy": "npm run test:health && npm run test:mobile:comprehensive",
    "dev": "zola serve --port 1111 --watch",
    "test:unit:jest": "jest",
    "test:unit:jest:watch": "jest --watch",
    "test:unit:jest:coverage": "jest --coverage",
    "test:unit:all": "npm run test:unit:jest && npm run test:unit",
    "style:validate": "node scripts/validate-style-guide.js",
    "style:test": "playwright test tests/style-guide-validation.spec.js",
    "style:check": "npm run style:validate && npm run style:test",
    "test:quick": "playwright test tests/new-divinci-site.spec.js --project=Desktop-Chrome",
    "test:navigation": "playwright test tests/language-health-check.spec.js --project=Desktop-Chrome",
    "test:e2e:safe": "echo 'Pre-push validation: Running unit tests and style checks...' && npm run test:unit:jest && npm run style:validate",
    "test:validate-setup": "node scripts/validate-test-setup.js",
    "pre-commit": "npm run test:unit:jest && npm run style:validate",
    "pre-push": "npm run test:e2e:safe && npm run style:check"
  },
  "dependencies": {
    "mimetext": "^3.0.27"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/jest": "^30.0.0",
    "glob": "^10.3.10",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.0.5",
    "jsdom": "^26.1.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/tests/unit/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "static/js/**/*.js",
      "!static/js/**/*.min.js",
      "!**/node_modules/**"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/unit/setup.js"
    ]
  }
}
