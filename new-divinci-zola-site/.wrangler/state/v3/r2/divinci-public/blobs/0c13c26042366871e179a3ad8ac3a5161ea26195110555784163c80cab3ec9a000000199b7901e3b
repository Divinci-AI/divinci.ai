<svg viewBox="0 0 900 600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <style>
      .pilot-title { font-family: 'Georgia', serif; font-size: 24px; font-weight: bold; fill: #2d3c34; }
      .pilot-label { font-family: 'Arial', sans-serif; font-size: 13px; fill: #2d3c34; }
      .pilot-value { font-family: 'Arial', sans-serif; font-size: 14px; font-weight: bold; fill: #2d3c34; }
      .pilot-small { font-family: 'Arial', sans-serif; font-size: 11px; fill: #2d3c34; }
      .pilot-bar { transition: transform 0.3s ease; }
      .pilot-bar:hover { transform: translateX(5px); }
    </style>
  </defs>

  <!-- Title -->
  <text x="450" y="35" text-anchor="middle" class="pilot-title">Real-World UBI Results: Evidence from Pilot Programs</text>
  <text x="450" y="60" text-anchor="middle" class="pilot-small" style="font-size: 12px; opacity: 0.7;">Across different cultures and economies, UBI shows consistent positive outcomes</text>

  <!-- Alaska Permanent Fund -->
  <g>
    <text x="50" y="105" class="pilot-label" style="font-weight: bold; font-size: 16px; fill: #2e7d32;">🇺🇸 Alaska Permanent Fund (1982-present)</text>
    <text x="50" y="125" class="pilot-small">$1,000-2,072 annually · 40+ years · Every resident</text>

    <!-- Labor participation -->
    <g class="pilot-bar">
      <rect x="50" y="140" width="400" height="35" fill="#b8e6b8" stroke="#2d3c34" stroke-width="1.5" rx="6"/>
      <text x="60" y="162" class="pilot-label">Labor force participation</text>
      <text x="440" y="162" text-anchor="end" class="pilot-value" style="fill: #2e7d32;">Unchanged ✓</text>
    </g>

    <!-- Poverty reduction -->
    <g class="pilot-bar">
      <rect x="50" y="180" width="400" height="35" fill="#b8e6b8" stroke="#2d3c34" stroke-width="1.5" rx="6"/>
      <text x="60" y="202" class="pilot-label">Child poverty reduction</text>
      <text x="440" y="202" text-anchor="end" class="pilot-value" style="fill: #2e7d32;">-20% ✓</text>
    </g>

    <!-- Inflation -->
    <g class="pilot-bar">
      <rect x="50" y="220" width="400" height="35" fill="#b8e6b8" stroke="#2d3c34" stroke-width="1.5" rx="6"/>
      <text x="60" y="242" class="pilot-label">Inflation concerns</text>
      <text x="440" y="242" text-anchor="end" class="pilot-value" style="fill: #2e7d32;">None ✓</text>
    </g>
  </g>

  <!-- Finland -->
  <g>
    <text x="480" y="105" class="pilot-label" style="font-weight: bold; font-size: 16px; fill: #2e7d32;">🇫🇮 Finland (2017-2018)</text>
    <text x="480" y="125" class="pilot-small">€560/month · 2,000 unemployed participants</text>

    <!-- Employment -->
    <g class="pilot-bar">
      <rect x="480" y="140" width="370" height="35" fill="#cfdcff" stroke="#2d3c34" stroke-width="1.5" rx="6"/>
      <text x="490" y="162" class="pilot-label">Employment rate change</text>
      <text x="840" y="162" text-anchor="end" class="pilot-value" style="fill: #2e7d32;">No change ✓</text>
    </g>

    <!-- Wellbeing -->
    <g class="pilot-bar">
      <rect x="480" y="180" width="370" height="35" fill="#cfdcff" stroke="#2d3c34" stroke-width="1.5" rx="6"/>
      <text x="490" y="202" class="pilot-label">Mental health & happiness</text>
      <text x="840" y="202" text-anchor="end" class="pilot-value" style="fill: #2e7d32;">Significant ↑ ✓</text>
    </g>

    <!-- Stress -->
    <g class="pilot-bar">
      <rect x="480" y="220" width="370" height="35" fill="#cfdcff" stroke="#2d3c34" stroke-width="1.5" rx="6"/>
      <text x="490" y="242" class="pilot-label">Stress reduction</text>
      <text x="840" y="242" text-anchor="end" class="pilot-value" style="fill: #2e7d32;">Major ↓ ✓</text>
    </g>
  </g>

  <!-- Kenya -->
  <g>
    <text x="50" y="290" class="pilot-label" style="font-weight: bold; font-size: 16px; fill: #2e7d32;">🇰🇪 Kenya (2018-ongoing)</text>
    <text x="50" y="310" class="pilot-small">$22.50/month · 23,000 participants · 12 years · World's largest UBI study</text>

    <!-- Economic activity -->
    <g class="pilot-bar">
      <rect x="50" y="325" width="400" height="35" fill="#e6b8ff" stroke="#2d3c34" stroke-width="1.5" rx="6"/>
      <text x="60" y="347" class="pilot-label">Economic activity & entrepreneurship</text>
      <text x="440" y="347" text-anchor="end" class="pilot-value" style="fill: #2e7d32;">Increased ✓</text>
    </g>

    <!-- Long-term benefits -->
    <g class="pilot-bar">
      <rect x="50" y="365" width="400" height="35" fill="#e6b8ff" stroke="#2d3c34" stroke-width="1.5" rx="6"/>
      <text x="60" y="387" class="pilot-label">Long-term vs short-term recipients</text>
      <text x="440" y="387" text-anchor="end" class="pilot-value" style="fill: #2e7d32;">Better outcomes ✓</text>
    </g>

    <!-- Investment -->
    <g class="pilot-bar">
      <rect x="50" y="405" width="400" height="35" fill="#e6b8ff" stroke="#2d3c34" stroke-width="1.5" rx="6"/>
      <text x="60" y="427" class="pilot-label">Business investment & education</text>
      <text x="440" y="427" text-anchor="end" class="pilot-value" style="fill: #2e7d32;">Significant ↑ ✓</text>
    </g>
  </g>

  <!-- Stockton -->
  <g>
    <text x="480" y="290" class="pilot-label" style="font-weight: bold; font-size: 16px; fill: #2e7d32;">🇺🇸 Stockton, CA (2019)</text>
    <text x="480" y="310" class="pilot-small">$500/month · 125 residents · Below median income</text>

    <!-- Employment -->
    <g class="pilot-bar">
      <rect x="480" y="325" width="370" height="35" fill="#f9d689" stroke="#2d3c34" stroke-width="1.5" rx="6"/>
      <text x="490" y="347" class="pilot-label">Employment outcomes</text>
      <text x="840" y="347" text-anchor="end" class="pilot-value" style="fill: #2e7d32;">Improved ✓</text>
    </g>

    <!-- Health -->
    <g class="pilot-bar">
      <rect x="480" y="365" width="370" height="35" fill="#f9d689" stroke="#2d3c34" stroke-width="1.5" rx="6"/>
      <text x="490" y="387" class="pilot-label">Anxiety & depression</text>
      <text x="840" y="387" text-anchor="end" class="pilot-value" style="fill: #2e7d32;">Reduced ✓</text>
    </g>

    <!-- Spending -->
    <g class="pilot-bar">
      <rect x="480" y="405" width="370" height="35" fill="#f9d689" stroke="#2d3c34" stroke-width="1.5" rx="6"/>
      <text x="490" y="427" class="pilot-label">Spending pattern</text>
      <text x="840" y="427" text-anchor="end" class="pilot-value" style="fill: #2e7d32;">Essentials (not luxuries) ✓</text>
    </g>
  </g>

  <!-- Summary box -->
  <rect x="50" y="470" width="800" height="100" fill="#fff3e0" stroke="#8b7659" stroke-width="3" rx="8"/>
  <text x="450" y="495" text-anchor="middle" class="pilot-label" style="font-weight: bold; font-size: 16px;">Consistent Findings Across All Studies</text>

  <text x="70" y="520" class="pilot-small">✓ Labor participation drops only 1-2% (mostly for education/family care)</text>
  <text x="520" y="520" class="pilot-small">✓ Entrepreneurship increases 15-20%</text>

  <text x="70" y="540" class="pilot-small">✓ Health outcomes improve significantly</text>
  <text x="520" y="540" class="pilot-small">✓ Children benefit most (nutrition, education)</text>

  <text x="70" y="560" class="pilot-small">✓ No inflation or economic collapse</text>
  <text x="520" y="560" class="pilot-small">✓ People want meaningful work, not just survival jobs</text>

  <!-- Public support note -->
  <text x="450" y="592" text-anchor="middle" class="pilot-small" style="font-size: 10px; opacity: 0.6;">71% of Europeans support UBI (Oxford 2020) · Alaska program has bipartisan political support after 40+ years</text>
</svg>
