<svg viewBox="0 0 800 500" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <style>
      .funding-title { font-family: 'Georgia', serif; font-size: 24px; font-weight: bold; fill: #2d3c34; }
      .funding-label { font-family: 'Arial', sans-serif; font-size: 14px; fill: #2d3c34; }
      .funding-value { font-family: 'Arial', sans-serif; font-size: 16px; font-weight: bold; fill: #2d3c34; }
      .funding-bar { transition: opacity 0.3s ease; }
      .funding-bar:hover { opacity: 0.8; }
    </style>
  </defs>

  <!-- Title -->
  <text x="400" y="30" text-anchor="middle" class="funding-title">UBI Funding Sources by 2035</text>
  <text x="400" y="55" text-anchor="middle" class="funding-label" style="font-size: 12px; opacity: 0.7;">Total Available: $3.95-6.15 Trillion Annually</text>

  <!-- Government Restructuring -->
  <g class="funding-bar">
    <rect x="50" y="90" width="480" height="50" fill="#cfdcff" stroke="#2d3c34" stroke-width="2" rx="5"/>
    <text x="60" y="120" class="funding-label">Government Restructuring</text>
    <text x="520" y="120" class="funding-value" text-anchor="end">$2.25T</text>
  </g>

  <!-- Bitcoin Reserve -->
  <g class="funding-bar">
    <rect x="50" y="155" width="380" height="50" fill="#f9d689" stroke="#2d3c34" stroke-width="2" rx="5"/>
    <text x="60" y="185" class="funding-label">Strategic Bitcoin Reserve</text>
    <text x="420" y="185" class="funding-value" text-anchor="end">$0.5-2T</text>
  </g>

  <!-- Proof-of-Useful-Work -->
  <g class="funding-bar">
    <rect x="50" y="220" width="250" height="50" fill="#b8e6b8" stroke="#2d3c34" stroke-width="2" rx="5"/>
    <text x="60" y="250" class="funding-label">Proof-of-Useful-Work</text>
    <text x="290" y="250" class="funding-value" text-anchor="end">$0.2-0.5T</text>
  </g>

  <!-- Economic Growth Multiplier -->
  <g class="funding-bar">
    <rect x="50" y="285" width="310" height="50" fill="#e6b8ff" stroke="#2d3c34" stroke-width="2" rx="5"/>
    <text x="60" y="315" class="funding-label">Economic Growth Multiplier</text>
    <text x="350" y="315" class="funding-value" text-anchor="end">$0.4-0.8T</text>
  </g>

  <!-- Welfare Consolidation -->
  <g class="funding-bar">
    <rect x="50" y="350" width="330" height="50" fill="#ffb8b8" stroke="#2d3c34" stroke-width="2" rx="5"/>
    <text x="60" y="380" class="funding-label">Existing Welfare Consolidation</text>
    <text x="370" y="380" class="funding-value" text-anchor="end">$0.6T</text>
  </g>

  <!-- Technology Cost Reduction (separate box) -->
  <g>
    <rect x="550" y="90" width="200" height="310" fill="#fff3e0" stroke="#8b7659" stroke-width="3" stroke-dasharray="5,5" rx="8"/>
    <text x="650" y="120" text-anchor="middle" class="funding-label" style="font-weight: bold;">Additional Value</text>
    <text x="650" y="145" text-anchor="middle" class="funding-label" style="font-size: 12px;">Technology Cost Reduction</text>

    <!-- Fusion Energy -->
    <circle cx="570" cy="180" r="8" fill="#cfdcff"/>
    <text x="585" y="185" class="funding-label" style="font-size: 11px;">Fusion Energy</text>
    <text x="740" y="185" class="funding-value" style="font-size: 13px;" text-anchor="end">$300-600/mo</text>

    <!-- Robotics -->
    <circle cx="570" cy="215" r="8" fill="#b8e6b8"/>
    <text x="585" y="220" class="funding-label" style="font-size: 11px;">Robotics/AI</text>
    <text x="740" y="220" class="funding-value" style="font-size: 13px;" text-anchor="end">~$200/mo</text>

    <!-- Total Equivalent -->
    <line x1="560" y1="260" x2="740" y2="260" stroke="#8b7659" stroke-width="2"/>
    <text x="650" y="285" text-anchor="middle" class="funding-label" style="font-weight: bold;">Per-Person Equivalent</text>
    <text x="650" y="310" text-anchor="middle" class="funding-value" style="font-size: 20px; fill: #8b7659;">$500-800/mo</text>
    <text x="650" y="335" text-anchor="middle" class="funding-label" style="font-size: 11px; opacity: 0.8;">Cost reductions = effective income</text>
  </g>

  <!-- Legend -->
  <text x="50" y="440" class="funding-label" style="font-size: 11px; opacity: 0.7;">Direct Cash Funding Sources (Left) | Technology-Driven Cost Reductions (Right)</text>
  <text x="50" y="460" class="funding-label" style="font-size: 11px; opacity: 0.7;">Effective UBI Value: $1,000-2,000/mo cash + $500-800/mo cost reduction = $1,500-2,800/mo total</text>
</svg>
