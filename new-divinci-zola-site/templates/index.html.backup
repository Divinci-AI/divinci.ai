                                <path d="M20 30 L30 30 L25 50 Z" fill="none" stroke="currentColor" stroke-width="2"/>
                                <path d="M70 30 L80 30 L75 50 Z" fill="none" stroke="currentColor" stroke-width="2"/>
                                <circle cx="50" cy="20" r="3" fill="currentColor"/>
                            </svg>
                        </span>
                        <div class="principle-text">
                            <h3>{{ translations.ai_for_good.principles.fair_ai.title | default(value="Fair AI") }}</h3>
                            <p>{{ translations.ai_for_good.principles.fair_ai.description | default(value="Bias reduction and fairness promotion in all outcomes.") }}</p>
                        </div>
                    </div>
                    <div class="principle">
                        <span class="principle-icon">
                            <svg class="sacred-icon impact-icon" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                                <circle cx="50" cy="50" r="15" fill="none" stroke="currentColor" stroke-width="2"/>
                                <circle cx="50" cy="35" r="15" fill="none" stroke="currentColor" stroke-width="1" opacity="0.6"/>
                                <circle cx="50" cy="65" r="15" fill="none" stroke="currentColor" stroke-width="1" opacity="0.6"/>
                                <circle cx="37" cy="42.5" r="15" fill="none" stroke="currentColor" stroke-width="1" opacity="0.6"/>
                                <circle cx="63" cy="42.5" r="15" fill="none" stroke="currentColor" stroke-width="1" opacity="0.6"/>
                                <circle cx="37" cy="57.5" r="15" fill="none" stroke="currentColor" stroke-width="1" opacity="0.6"/>
                                <circle cx="63" cy="57.5" r="15" fill="none" stroke="currentColor" stroke-width="1" opacity="0.6"/>
                            </svg>
                        </span>
                        <div class="principle-text">
                            <h3>{{ translations.ai_for_good.principles.positive_impact.title | default(value="Positive impact") }}</h3>
                            <p>{{ translations.ai_for_good.principles.positive_impact.description | default(value="Contributing to solutions that address global challenges.") }}</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="ai-for-good-image">
                <img src="{{ get_url(path="images/ai-for-impact-1.avif") }}" alt="AI for Good Impact">
            </div>
        </div>
    </div>
</section>

<!-- Expert Answers Section -->
<section class="expert-answers-section">
    <div class="expert-answers-container">
        <div class="expert-answers-content">
            <h2>{{ translations.expert_answers.title | default(value="Expert answers. Enterprise clarity.") }}</h2>
            <p class="expert-answers-description">{{ translations.expert_answers.description | default(value="Find comprehensive insights on our platform's release management and quality assurance for large language models. Explore detailed, professional responses to your most pressing questions.") }}</p>

            <div class="faq-accordion">
                <div class="faq-item">
                    <button class="faq-question">
                        {{ translations.expert_answers.faqs.model_reliability.question | default(value="How do you guarantee model reliability?") }}
                        <span class="faq-icon">+</span>
                    </button>
                    <div class="faq-answer">
                        <p>{{ translations.expert_answers.faqs.model_reliability.answer | default(value="We implement a multi-layered validation process, combining automated regression, performance, and security testing with expert manual reviews. Each model release is rigorously assessed to ensure it consistently meets enterprise-grade standards for accuracy, stability, and compliance.") }}</p>
                    </div>
                </div>

                <div class="faq-item">
                    <button class="faq-question">
                        {{ translations.expert_answers.faqs.language_models.question | default(value="Which language models are compatible?") }}
                        <span class="faq-icon">+</span>
                    </button>
                    <div class="faq-answer">
                        <p>{{ translations.expert_answers.faqs.language_models.answer | default(value="Our platform supports all major language models including GPT-4, Claude, Gemini, and custom fine-tuned models. We provide unified APIs and governance frameworks that work seamlessly across different model providers.") }}</p>
                    </div>
                </div>

                <div class="faq-item">
                    <button class="faq-question">
                        {{ translations.expert_answers.faqs.quality_assurance.question | default(value="How is ongoing quality assurance achieved?") }}
                        <span class="faq-icon">+</span>
                    </button>
                    <div class="faq-answer">
                        <p>{{ translations.expert_answers.faqs.quality_assurance.answer | default(value="We employ continuous monitoring with automated performance tracking, bias detection, and compliance verification. Our system provides real-time alerts, detailed analytics, and automated rollback capabilities to maintain consistent quality standards.") }}</p>
                    </div>
                </div>

                <div class="faq-item">
                    <button class="faq-question">
                        {{ translations.expert_answers.faqs.workflow_integration.question | default(value="Does the platform fit existing workflows?") }}
                        <span class="faq-icon">+</span>
                    </button>
                    <div class="faq-answer">
                        <p>{{ translations.expert_answers.faqs.workflow_integration.answer | default(value="Yes, our platform is designed for seamless integration with existing DevOps, MLOps, and enterprise workflows. We provide comprehensive APIs, webhooks, and integrations with popular tools like Jenkins, GitHub Actions, and enterprise monitoring systems.") }}</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

