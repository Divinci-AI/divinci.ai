{% extends "base.html" %}

{% block title %}
  {{ translations.meta.title | default(value="Divinci AI - Excellence, every time") }}
{% endblock %}

{% block content %}

{% include "partials/header.html" %}

<section class="hero">
    <div class="hero-content">
        <div class="hero-image">
            <img src="{{ get_url(path="images/Davinci_the_painter_painting_a_robot_in_a_line_art.webp") }}" alt="Leonardo da Vinci drawing a robot" class="davinci-image" id="hero-poster">
            <video id="hero-video" muted loop playsinline preload="metadata" data-lazy-video>
                <source src="{{ get_url(path="images/Video_of_Robot_Creation_Ready.webm") }}" type="video/webm">
                <source src="{{ get_url(path="images/Video_of_Robot_Creation_Ready.mp4") }}" type="video/mp4">
            </video>
            <button id="sound-toggle" style="display: none;">Unmute</button>
        </div>
        <div class="hero-text">
            <h1>
                {{ translations.hero.heading | default(value="AI releases.") }}<br>
                {{ translations.hero.subheading | default(value="Excellence, every time.") }}
            </h1>
            <p>
                {{ translations.hero.description | default(value="Empower your business with advanced release management and rigorous quality assurance for custom language models. Achieve operational reliability, regulatory compliance, and optimal performance through a structured, end-to-end deployment process.") }}
            </p>
            <div class="features">
                <div class="feature">
                    <span class="feature-icon feature-icon-star">✧</span>
                    <span class="feature-text">{{ translations.hero.features.test_automation | default(value="Intelligent test automation") }}</span>
                </div>
                <div class="feature">
                    <span class="feature-icon feature-icon-rotate">↻</span>
                    <span class="feature-text">{{ translations.hero.features.compliance_records | default(value="Detailed compliance records") }}</span>
                </div>
                <div class="feature">
                    <span class="feature-icon feature-icon-heart">♡</span>
                    <span class="feature-text">{{ translations.hero.features.version_recovery | default(value="Instant version recovery") }}</span>
                </div>
            </div>
            <div class="cta-buttons">
                <button class="primary-button">{{ translations.hero.cta.primary | default(value="Request demo") }}</button>
                <button class="secondary-button">{{ translations.hero.cta.secondary | default(value="Explore platform") }}</button>
            </div>
        </div>
    </div>
</section>

<section class="enterprise-ai" id="solutions">
    <div class="enterprise-header">
        <h2>{{ translations.enterprise.title | default(value="Enterprise AI, expertly managed") }}</h2>
        <p class="section-intro">{{ translations.enterprise.description | default(value="Unlock robust release management and rigorous quality assurance for large language models. Our platform equips enterprises with advanced tools to streamline deployment, enforce compliance, and ensure consistent, high-quality AI performance at scale.") }}</p>
    </div>
    <div class="video-background-container">
        <!-- Default background video -->
        <video id="background-video-default" class="background-video active" muted loop playsinline preload="metadata" data-lazy-video>
            <source src="{{ get_url(path="images/background-video.webm") }}" type="video/webm">
        </video>
        
        <!-- Panel 2 hover video (business parody) -->
        <video id="background-video-panel2" class="background-video" muted loop playsinline preload="none" data-lazy-video data-panel="2">
            <source src="{{ get_url(path="images/business-parody-optimized.webm") }}" type="video/webm">
            <source src="{{ get_url(path="images/business-parody-social_u4943574663_Renaissance_fresco._Almost_parody_hybrid_scene_of_2ce28274-76c9-4ec1-b4f8-3acc57789616_3.mp4") }}" type="video/mp4">
        </video>
        
        <!-- Panel 3 hover video (rag machine) -->
        <video id="background-video-panel3" class="background-video" muted loop playsinline preload="none" data-lazy-video data-panel="3">
            <source src="{{ get_url(path="images/rag-machine-optimized.webm") }}" type="video/webm">
            <source src="{{ get_url(path="images/rag-machine-social_u4943574663_Young_Leonardo_da_Vinci_in_Renaissance_workshop_t_ad808b44-961d-49e8-b0db-06c848541449_1.mp4") }}" type="video/mp4">
        </video>
    </div>
    <div class="enterprise-content">
        <div class="circular-panels-wrapper">
            <div class="panels-container">
                <div class="panel default-open">
                    <div class="panel-art">
                        <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                            <path d="M50 10 C 20 10, 10 50, 50 90 S 80 90, 90 50 S 60 10, 50 10" fill="none" stroke="currentColor" stroke-width="2"/>
                            <path d="M50 10 C 80 10, 90 50, 50 90 S 20 90, 10 50 S 40 10, 50 10" fill="none" stroke="currentColor" stroke-width="2"/>
                        </svg>
                    </div>
                    <h3>{{ translations.enterprise.features.release_orchestration.title | default(value="Intelligent release orchestration") }}</h3>
                    <p>{{ translations.enterprise.features.release_orchestration.description | default(value="Automate and coordinate complex deployment pipelines with precision. Ensure every model release is validated, documented, and seamlessly transitioned to production, minimizing risk and maximizing operational efficiency.") }}</p>
                </div>
                <div class="panel panel-with-bg">
                    <div class="panel-art">
                        <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="50" cy="50" r="45" fill="none" stroke="currentColor" stroke-width="2"/>
                            <circle cx="50" cy="50" r="30" fill="none" stroke="currentColor" stroke-width="2"/>
                            <circle cx="50" cy="50" r="15" fill="none" stroke="currentColor" stroke-width="2"/>
                            <circle cx="50" cy="50" r="5" fill="currentColor"/>
                        </svg>
                    </div>
                    <h3>
{{ translations.enterprise.features.model_oversight.title | default(value="Proactive model oversight") }}
                    </h3>
                    <p>{{ translations.enterprise.features.model_oversight.description | default(value="Monitor model performance and compliance in real time. Leverage automated checks and comprehensive analytics to detect issues early, uphold regulatory standards, and maintain optimal model integrity.") }}</p>
                </div>
                <div class="panel">
                    <div class="panel-art">
                        <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                            <!-- Fibonacci spiral with golden ratio rectangles -->
                            <path d="M50 50 A 8 8 0 0 1 42 58 A 13 13 0 0 1 29 45 A 21 21 0 0 1 50 24 A 34 34 0 0 1 84 58 A 55 55 0 0 1 29 113" fill="none" stroke="currentColor" stroke-width="1.5" class="fibonacci-spiral"/>
                            <!-- Golden ratio rectangles -->
                            <rect x="42" y="50" width="8" height="8" fill="none" stroke="currentColor" stroke-width="1" class="golden-rect-1"/>
                            <rect x="29" y="45" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1" class="golden-rect-2"/>
                            <rect x="29" y="24" width="21" height="21" fill="none" stroke="currentColor" stroke-width="1" class="golden-rect-3"/>
                            <rect x="50" y="24" width="34" height="34" fill="none" stroke="currentColor" stroke-width="1" class="golden-rect-4"/>
                        </svg>
                    </div>
                    <h3>
{{ translations.enterprise.features.performance_analytics.title | default(value="Tailored performance analytics") }}
                    </h3>
                    <p>
{{ translations.enterprise.features.performance_analytics.description | default(value="Establish and track custom evaluation metrics aligned with your business objectives. Analyze accuracy, bias, and other critical factors to inform strategic decisions throughout the model lifecycle.") }}
                    </p>
                </div>
                <div class="panel">
                    <div class="panel-art">
                        <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                            <path d="M10 50 L50 10 L90 50 L50 90 Z" fill="none" stroke="currentColor" stroke-width="2"/>
                            <path d="M10 50 L50 90 L90 50 L50 10 Z" fill="none" stroke="currentColor" stroke-width="2" transform="rotate(45 50 50)"/>
                        </svg>
                    </div>
                    <h3>
{{ translations.enterprise.features.team_collaboration.title | default(value="Integrated team collaboration") }}
                    </h3>
                    <p>
{{ translations.enterprise.features.team_collaboration.description | default(value="Streamline cross-functional reviews with structured workflows. Assign responsibilities, collect feedback, and document approvals to ensure every release meets organizational and regulatory expectations.") }}
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="features-section" id="features">
    <div class="background-sketches">
        <svg class="feature-bg-sketch" viewBox="0 0 1920 1080" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
            <!-- Collaborative Review sketch - hand-drawn circles with annotations -->
            <g class="sketch-layer" data-feature="multiplayer">
                <path d="M 298 80 Q 320 78, 340 82 T 380 95 Q 410 110, 415 140 T 410 190 Q 400 220, 370 235 T 310 245 Q 270 240, 250 210 T 235 150 Q 240 110, 270 90 T 298 80" 
                      fill="none" stroke="#8b7355" stroke-width="1" opacity="0.15" stroke-linecap="round"/>
                <path d="M 498 180 Q 525 178, 545 185 T 580 205 Q 605 225, 608 255 T 600 305 Q 585 335, 555 345 T 490 350 Q 450 340, 430 310 T 415 250 Q 425 210, 455 190 T 498 180" 
                      fill="none" stroke="#8b7355" stroke-width="1" opacity="0.15" stroke-linecap="round"/>
                <path d="M 395 330 Q 420 328, 445 335 T 485 355 Q 510 375, 512 405 T 505 455 Q 490 485, 460 495 T 395 500 Q 355 490, 335 460 T 320 400 Q 325 360, 360 340 T 395 330" 
                      fill="none" stroke="#8b7355" stroke-width="1" opacity="0.15" stroke-linecap="round"/>
                <path d="M 305 318 Q 350 380, 398 448 Q 420 470, 498 418" fill="none" stroke="#8b7355" stroke-width="0.8" opacity="0.1" stroke-linecap="round"/>
                <path d="M 198 102 Q 300 140, 402 148 Q 500 155, 598 98 Q 700 140, 802 152 Q 900 158, 1002 148" fill="none" stroke="#8b7355" stroke-width="0.5" opacity="0.08" stroke-linecap="round"/>
                <!-- Handwritten annotations -->
                <text x="280" y="160" font-family="cursive" font-size="11" fill="#8b7355" opacity="0.15" font-style="italic" transform="rotate(-10 280 160)">reviewer_1</text>
                <text x="480" y="270" font-family="cursive" font-size="11" fill="#8b7355" opacity="0.15" font-style="italic" transform="rotate(5 480 270)">reviewer_2</text>
                <text x="380" y="420" font-family="cursive" font-size="11" fill="#8b7355" opacity="0.15" font-style="italic" transform="rotate(-5 380 420)">reviewer_3</text>
                <text x="350" y="390" font-family="cursive" font-size="10" fill="#8b7355" opacity="0.12" font-style="italic">consensus</text>
            </g>
            <!-- Model Registry sketch - precise rectangles with organic annotations -->
            <g class="sketch-layer" data-feature="ai_family">
                <!-- Precise outer rectangle -->
                <rect x="1200" y="100" width="400" height="300" fill="none" stroke="#8b7355" stroke-width="1" opacity="0.1" transform="rotate(15 1400 250)"/>
                <!-- Precise inner rectangle -->
                <rect x="1220" y="120" width="360" height="260" fill="none" stroke="#8b7355" stroke-width="0.8" opacity="0.08" transform="rotate(15 1400 250)"/>
                <!-- Organic text lines -->
                <path d="M 1298 202 Q 1350 198, 1402 200 T 1502 198 M 1302 248 Q 1350 252, 1398 250 T 1498 252 M 1295 302 Q 1350 298, 1405 300 T 1505 298" 
                      stroke="#8b7355" stroke-width="0.5" opacity="0.1" stroke-linecap="round" transform="rotate(15 1400 250)"
                      class="draw-animated"
                      style="--animation-delay: 3.5s; --target-opacity: 0.1;"/>
                <!-- Handwritten annotation -->
                <text x="1250" y="180" font-family="cursive" font-size="14" fill="#8b7355" opacity="0.2" font-style="italic" transform="rotate(15 1400 250)"
                      class="fade-in-text"
                      style="--animation-delay: 3.7s; --target-opacity: 0.2;">version_control.init()</text>
                <path d="M 1300 170 L 1350 160" stroke="#8b7355" stroke-width="0.3" opacity="0.15" transform="rotate(15 1400 250)"/>
            </g>
            <!-- Interactive Testing sketch - hand-drawn sound waves -->
            <g class="sketch-layer" data-feature="voice_io">
                <path d="M 1598 550 Q 1615 548, 1630 552 T 1648 565 Q 1650 580, 1645 595 T 1625 615 Q 1610 618, 1590 615 T 1555 598 Q 1552 580, 1558 565 T 1598 550" 
                      fill="none" stroke="#8b7355" stroke-width="1" opacity="0.12" stroke-linecap="round"/>
                <path d="M 1595 500 Q 1625 498, 1655 505 T 1695 530 Q 1702 560, 1698 590 T 1675 640 Q 1645 655, 1610 658 T 1540 645 Q 1505 625, 1502 590 T 1510 525 Q 1530 505, 1560 502 T 1595 500" 
                      fill="none" stroke="#8b7355" stroke-width="0.8" opacity="0.08" stroke-linecap="round"/>
                <path d="M 1592 450 Q 1635 448, 1680 458 T 1745 490 Q 1752 535, 1748 580 T 1720 665 Q 1680 695, 1635 698 T 1545 685 Q 1500 660, 1455 615 Q 1448 570, 1455 525 T 1485 455 Q 1525 445, 1560 448 T 1592 450" 
                      fill="none" stroke="#8b7355" stroke-width="0.6" opacity="0.05" stroke-linecap="round"/>
                <path d="M 1448 602 Q 1520 520, 1598 452 Q 1680 380, 1752 598 Q 1680 680, 1602 748 Q 1520 680, 1448 602" 
                      fill="none" stroke="#8b7355" stroke-width="1" opacity="0.1" stroke-linecap="round"/>
            </g>
            <!-- Quality Metrics sketch - precise grid with organic data line -->
            <g class="sketch-layer" data-feature="performance_analytics">
                <!-- Organic data line -->
                <path d="M 98 802 Q 150 750, 202 698 Q 250 725, 298 752 Q 350 675, 402 598 Q 450 625, 498 652 Q 550 575, 602 498" 
                      fill="none" stroke="#8b7355" stroke-width="1.5" opacity="0.1" stroke-linecap="round"/>
                <!-- Precise grid lines -->
                <line x1="50" y1="850" x2="650" y2="850" stroke="#8b7355" stroke-width="0.8" opacity="0.08"/>
                <line x1="50" y1="450" x2="50" y2="850" stroke="#8b7355" stroke-width="0.8" opacity="0.08"/>
                <!-- Grid marks -->
                <line x1="150" y1="845" x2="150" y2="855" stroke="#8b7355" stroke-width="0.5" opacity="0.1"/>
                <line x1="250" y1="845" x2="250" y2="855" stroke="#8b7355" stroke-width="0.5" opacity="0.1"/>
                <line x1="350" y1="845" x2="350" y2="855" stroke="#8b7355" stroke-width="0.5" opacity="0.1"/>
                <line x1="450" y1="845" x2="450" y2="855" stroke="#8b7355" stroke-width="0.5" opacity="0.1"/>
                <line x1="550" y1="845" x2="550" y2="855" stroke="#8b7355" stroke-width="0.5" opacity="0.1"/>
                <!-- Data point -->
                <circle cx="400" cy="600" r="8" fill="#8b7355" opacity="0.15"/>
                <!-- Handwritten labels -->
                <text x="30" y="440" font-family="cursive" font-size="12" fill="#8b7355" opacity="0.2" font-style="italic" transform="rotate(-90 30 440)">latency_ms</text>
                <text x="660" y="865" font-family="cursive" font-size="12" fill="#8b7355" opacity="0.2" font-style="italic">time →</text>
            </g>
            <!-- Compliance Suite sketch - precise shield with organic details -->
            <g class="sketch-layer" data-feature="enterprise_security">
                <!-- Precise shield outline using straight lines -->
                <path d="M 900 500 L 1000 450 L 1100 500 L 1100 650 L 1000 750 L 900 650 Z" 
                      fill="none" stroke="#8b7355" stroke-width="1.2" opacity="0.1"/>
                <!-- Organic lock circle -->
                <path d="M 995 540 Q 1015 538, 1035 545 T 1045 570 Q 1042 590, 1025 605 T 985 615 Q 965 608, 958 585 T 960 555 Q 970 542, 985 540 T 995 540" 
                      fill="none" stroke="#8b7355" stroke-width="0.8" opacity="0.08" stroke-linecap="round"/>
                <!-- Precise keyhole -->
                <rect x="990" y="580" width="20" height="60" fill="#8b7355" opacity="0.05"/>
                <!-- Handwritten annotation -->
                <text x="920" y="530" font-family="cursive" font-size="11" fill="#8b7355" opacity="0.2" font-style="italic">auth.verify()</text>
            </g>
            <!-- CI/CD Pipelines sketch - mixed precise and organic workflow -->
            <g class="sketch-layer" data-feature="smart_workflows">
                <!-- Precise outer circle -->
                <circle cx="800" cy="300" r="80" fill="none" stroke="#8b7355" stroke-width="1" opacity="0.1"/>
                <!-- Organic workflow arrows -->
                <path d="M 798 222 Q 835 235, 862 268 T 878 298" stroke="#8b7355" stroke-width="1.5" opacity="0.12" fill="none" marker-end="url(#sketch-arrow)" stroke-linecap="round"/>
                <path d="M 878 302 Q 865 335, 832 358 T 802 378" stroke="#8b7355" stroke-width="1.5" opacity="0.12" fill="none" marker-end="url(#sketch-arrow)" stroke-linecap="round"/>
                <path d="M 798 378 Q 762 365, 738 332 T 722 302" stroke="#8b7355" stroke-width="1.5" opacity="0.12" fill="none" marker-end="url(#sketch-arrow)" stroke-linecap="round"/>
                <path d="M 722 298 Q 735 265, 768 238 T 798 222" stroke="#8b7355" stroke-width="1.5" opacity="0.12" fill="none" marker-end="url(#sketch-arrow)" stroke-linecap="round"/>
                <!-- Handwritten stage labels -->
                <text x="820" y="250" font-family="cursive" font-size="10" fill="#8b7355" opacity="0.15" font-style="italic">build</text>
                <text x="850" y="340" font-family="cursive" font-size="10" fill="#8b7355" opacity="0.15" font-style="italic">test</text>
                <text x="750" y="360" font-family="cursive" font-size="10" fill="#8b7355" opacity="0.15" font-style="italic">deploy</text>
                <text x="730" y="270" font-family="cursive" font-size="10" fill="#8b7355" opacity="0.15" font-style="italic">monitor</text>
            </g>
            <!-- Release Velocity sketch - precise lightning with organic details -->
            <g class="sketch-layer" data-feature="lightning_responses">
                <!-- Precise lightning bolt -->
                <path d="M 1200 800 L 1100 650 L 1250 650 L 1150 500 L 1300 650 L 1200 650 Z" 
                      fill="none" stroke="#8b7355" stroke-width="1" opacity="0.1"/>
                <!-- Organic energy circle -->
                <path d="M 1195 500 Q 1245 498, 1290 515 T 1345 560 Q 1352 610, 1345 660 T 1310 740 Q 1265 775, 1215 780 T 1115 765 Q 1065 730, 1055 680 T 1060 580 Q 1085 530, 1130 505 T 1195 500" 
                      fill="none" stroke="#8b7355" stroke-width="0.5" opacity="0.05" stroke-linecap="round"/>
                <path d="M 1048 652 Q 1125 580, 1202 548 Q 1275 580, 1352 648" 
                      fill="none" stroke="#8b7355" stroke-width="0.8" opacity="0.08" stroke-linecap="round"/>
                <!-- Handwritten annotation -->
                <text x="1220" y="720" font-family="cursive" font-size="12" fill="#8b7355" opacity="0.15" font-style="italic" transform="rotate(-15 1220 720)">velocity++</text>
            </g>
            <!-- Test Scenarios sketch - hand-drawn target circles -->
            <g class="sketch-layer" data-feature="domain_specialization">
                <path d="M 348 490 Q 365 488, 385 495 T 408 515 Q 412 535, 408 555 T 385 585 Q 365 592, 345 590 T 305 575 Q 288 555, 290 535 T 305 495 Q 325 488, 345 490 T 348 490" 
                      fill="none" stroke="#8b7355" stroke-width="1" opacity="0.1" stroke-linecap="round"/>
                <path d="M 345 450 Q 375 448, 405 458 T 445 485 Q 452 520, 448 555 T 425 610 Q 395 635, 360 638 T 290 625 Q 255 600, 248 565 T 255 495 Q 275 460, 310 452 T 345 450" 
                      fill="none" stroke="#8b7355" stroke-width="0.8" opacity="0.08" stroke-linecap="round"/>
                <path d="M 342 410 Q 385 408, 430 420 T 485 455 Q 492 505, 488 555 T 455 640 Q 415 675, 370 678 T 280 665 Q 235 630, 208 585 T 210 475 Q 235 425, 280 415 T 342 410" 
                      fill="none" stroke="#8b7355" stroke-width="0.6" opacity="0.06" stroke-linecap="round"/>
                <path d="M 345 545 Q 352 542, 358 548 T 355 558 Q 350 560, 345 558 T 342 550 Q 344 545, 345 545" fill="#8b7355" opacity="0.15"
                      class="pulsing"
                      style="--animation-delay: 3.8s;"/>
            </g>
            <!-- MLOps Integration sketch - hand-drawn connected nodes -->
            <g class="sketch-layer" data-feature="api_integration">
                <path d="M 695 660 Q 710 658, 728 665 T 738 685 Q 740 700, 735 715 T 715 728 Q 700 732, 685 728 T 662 710 Q 658 695, 665 680 T 695 660" 
                      fill="none" stroke="#8b7355" stroke-width="1" opacity="0.1" stroke-linecap="round"/>
                <path d="M 595 760 Q 612 758, 628 765 T 638 785 Q 640 802, 635 818 T 615 828 Q 598 832, 582 828 T 562 810 Q 558 792, 565 778 T 595 760" 
                      fill="none" stroke="#8b7355" stroke-width="1" opacity="0.1" stroke-linecap="round"/>
                <path d="M 795 762 Q 812 760, 828 768 T 838 788 Q 840 805, 835 820 T 815 830 Q 798 833, 782 830 T 762 812 Q 758 795, 765 780 T 795 762" 
                      fill="none" stroke="#8b7355" stroke-width="1" opacity="0.1" stroke-linecap="round"/>
                <path d="M 698 742 Q 702 750, 698 762" stroke="#8b7355" stroke-width="1.2" opacity="0.12" stroke-linecap="round"/>
                <path d="M 698 762 Q 670 775, 642 788" stroke="#8b7355" stroke-width="1.2" opacity="0.12" stroke-linecap="round"/>
                <path d="M 702 762 Q 730 775, 758 792" stroke="#8b7355" stroke-width="1.2" opacity="0.12" stroke-linecap="round"/>
                <path d="M 695 758 Q 702 755, 708 760 T 705 768 Q 700 770, 695 768 T 692 762 Q 693 758, 695 758" fill="#8b7355" opacity="0.2"
                      class="pulsing"
                      style="--animation-delay: 4.2s;"/>
            </g>
            <!-- Enterprise Scale sketch - precise squares with organic growth arrows -->
            <g class="sketch-layer" data-feature="scalability">
                <!-- Precise nested squares -->
                <rect x="1400" y="400" width="100" height="100" fill="none" stroke="#8b7355" stroke-width="1" opacity="0.12"/>
                <rect x="1380" y="380" width="140" height="140" fill="none" stroke="#8b7355" stroke-width="0.8" opacity="0.08"/>
                <rect x="1360" y="360" width="180" height="180" fill="none" stroke="#8b7355" stroke-width="0.6" opacity="0.05"/>
                <!-- Organic growth arrows -->
                <path d="M 1448 452 Q 1452 400, 1448 352 M 1452 448 Q 1500 452, 1548 448" 
                      stroke="#8b7355" stroke-width="0.5" opacity="0.1" stroke-linecap="round"
                      class="draw-animated"
                      style="--animation-delay: 4.5s; --target-opacity: 0.1;"/>
                <!-- Handwritten annotation -->
                <text x="1550" y="450" font-family="cursive" font-size="12" fill="#8b7355" opacity="0.2" font-style="italic">n → ∞</text>
            </g>
            <!-- Fibonacci spiral background - hand-drawn -->
            <path d="M 958 542 Q 918 582, 862 638 Q 758 628, 662 442 Q 672 282, 958 142 Q 1158 152, 1358 542" 
                  fill="none" stroke="#8b7355" stroke-width="0.5" opacity="0.03" stroke-linecap="round"/>
            
            <defs>
                <marker id="sketch-arrow" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
                    <polygon points="0 0, 10 3.5, 0 7" fill="#8b7355" opacity="0.2"/>
                </marker>
                <!-- Pencil texture filter -->
                <filter id="pencil-texture">
                    <feTurbulence type="fractalNoise" baseFrequency="0.02" numOctaves="5" result="noise" seed="1"/>
                    <feDisplacementMap in="SourceGraphic" in2="noise" scale="0.5"/>
                    <feGaussianBlur stdDeviation="0.1"/>
                </filter>
            </defs>
        </svg>
    </div>
    <div class="features-container">
        <div class="features-header">
            <h2>{{ translations.features.title | default(value="The Age of AI Management") }}</h2>
            <p class="section-intro">{{ translations.features.description | default(value="Discover features designed for enterprise teams that need reliable, scalable AI collaboration.") }}</p>
        </div>
        <div class="davinci-journal-showcase">
            <div class="journal-stack">
                <!-- <h3 class="journal-title">{{ translations.features.journal_title | default(value="Da Vinci's Innovation Codex") }}</h3> -->
                <div class="journal-pages-container">
                    <div class="journal-page" data-feature="multiplayer" tabindex="0">
                        <!-- Electric border SVG -->
