<section class="signup-section" id="signup">
    <div class="signup-container">
        <div class="signup-content">
            <h2>{{ translations.signup.title | default(value="Start your AI journey") }}</h2>
            <p class="signup-intro">{{ translations.signup.description | default(value="Join thousands of teams already transforming their work with Divinci AI. Get early access to our platform.") }}</p>
            <div class="signup-form">
                <form action="/signup" method="post">
                    <div class="form-group">
                        <input type="email" name="email" required placeholder="{{ translations.signup.email_placeholder | default(value="Your email") }}">
                        <button type="submit" class="signup-button">{{ translations.signup.button | default(value="Request access") }}</button>
                    </div>
                </form>
