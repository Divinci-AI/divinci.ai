                                    <path d="M 45 30 L 50 28 L 55 30 L 60 28 L 65 30 L 70 28 L 75 30 L 80 28 L 85 30 L 90 28 L 95 30 L 100 28 L 105 30 L 110 28 L 115 30 L 120 28 L 125 30 L 130 28 L 135 30 L 140 28 L 145 30 L 150 28 L 155 30" 
                                          stroke="#8b7355" stroke-width="0.5" opacity="0.4" fill="none"/>
                                    <!-- Atmospheric pressure indicators -->
                                    <circle cx="50" cy="25" r="2" fill="#8b7355" opacity="0.3"/>
                                    <circle cx="100" cy="20" r="2" fill="#8b7355" opacity="0.3"/>
                                    <circle cx="150" cy="25" r="2" fill="#8b7355" opacity="0.3"/>
                                    <!-- Primary lightning path - stepped leader -->
                                    <path d="M 100 50 L 98 65 L 102 64 L 96 82 L 104 81 L 94 102 L 106 100 L 92 125 L 108 123 L 88 150 L 112 148 L 95 175 L 100 180" 
                                          stroke="#8b7355" stroke-width="1" opacity="0.7" fill="none" stroke-linecap="round"/>
                                    <!-- Return stroke path -->
                                    <path d="M 100 180 L 98 175 Q 100 170, 102 165 L 100 150" 
                                          stroke="#8b7355" stroke-width="0.6" opacity="0.5" stroke-dasharray="2,1"/>
                                    <!-- Secondary branches -->
                                    <path d="M 95 70 L 85 75 M 105 68 L 115 73" stroke="#8b7355" stroke-width="0.4" opacity="0.3"/>
                                    <path d="M 90 95 L 75 100 M 110 92 L 125 97" stroke="#8b7355" stroke-width="0.4" opacity="0.3"/>
                                    <path d="M 85 125 L 70 130 M 115 120 L 130 125" stroke="#8b7355" stroke-width="0.4" opacity="0.3"/>
                                    <!-- Ground connection points -->
                                    <path d="M 20 180 L 180 180" stroke="#8b7355" stroke-width="0.5" opacity="0.4"/>
                                    <path d="M 90 180 L 95 175 M 100 180 L 100 175 M 110 180 L 105 175" stroke="#8b7355" stroke-width="0.6" opacity="0.5"/>
                                    <!-- Electric field lines -->
                                    <path d="M 60 60 Q 70 70, 60 80" stroke="#8b7355" stroke-width="0.3" opacity="0.2" stroke-dasharray="1,2"/>
                                    <path d="M 140 60 Q 130 70, 140 80" stroke="#8b7355" stroke-width="0.3" opacity="0.2" stroke-dasharray="1,2"/>
                                    <!-- Annotations -->
                                    <text x="100" y="15" font-family="Kalam, cursive" font-size="7" fill="#8b7355" opacity="0.5" text-anchor="middle">cumulonimbus</text>
                                    <text x="160" y="35" font-family="Kalam, cursive" font-size="6" fill="#8b7355" opacity="0.4">ρ⁺ = 10⁻⁸ C/m³</text>
                                    <text x="25" y="40" font-family="Kalam, cursive" font-size="6" fill="#8b7355" opacity="0.4">ρ⁻ = -10⁻⁸ C/m³</text>
                                    <text x="100" y="195" font-family="Kalam, cursive" font-size="8" fill="#8b7355" opacity="0.5" text-anchor="middle">terra conductrix</text>
                                    <!-- Speed notation -->
                                    <text x="20" y="150" font-family="Kalam, cursive" font-size="7" fill="#8b7355" opacity="0.4">v ≈ 3×10⁸ m/s</text>
                                    <!-- Time markers -->
                                    <text x="130" y="70" font-family="Kalam, cursive" font-size="6" fill="#8b7355" opacity="0.3">t₁</text>
                                    <text x="135" y="100" font-family="Kalam, cursive" font-size="6" fill="#8b7355" opacity="0.3">t₂</text>
                                    <text x="140" y="130" font-family="Kalam, cursive" font-size="6" fill="#8b7355" opacity="0.3">t₃</text>
                                </svg>
