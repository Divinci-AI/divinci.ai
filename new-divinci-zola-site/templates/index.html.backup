</section>

<svg style="display: none;">
    <defs>
        <filter id="fresco-texture">
            <feTurbulence type="fractalNoise" baseFrequency="0.05" numOctaves="2" result="noise"/>
            <feDiffuseLighting in="noise" lightingColor="white" surfaceScale="2" result="light">
                <feDistantLight azimuth="225" elevation="45"/>
            </feDiffuseLighting>
            <feComposite in="SourceGraphic" in2="light" operator="arithmetic" k1="1" k2="0" k3="0" k4="0"/>
        </filter>
    </defs>
</svg>

{% include "partials/footer.html" %}

<script>
// Background sketch interactive opacity and navigation
document.addEventListener('DOMContentLoaded', function() {
    const journalPages = document.querySelectorAll('.journal-page');
    const sketchLayers = document.querySelectorAll('.sketch-layer');
    const featureContents = document.querySelectorAll('.feature-content');
    const prevButton = document.querySelector('.nav-prev');
    const nextButton = document.querySelector('.nav-next');
    
    let currentPageIndex = 0;
    
    // Update navigation button states
    function updateNavButtons() {
        prevButton.disabled = currentPageIndex === 0;
        nextButton.disabled = currentPageIndex === journalPages.length - 1;
    }
    
    // Navigate to a specific page
    function navigateToPage(index) {
        if (index < 0 || index >= journalPages.length) return;
        
        // Remove active states
        journalPages.forEach(page => page.classList.remove('active'));
        featureContents.forEach(content => content.classList.remove('active'));
        sketchLayers.forEach(sketch => sketch.classList.remove('active-sketch'));
        
        // Add active state to current page
        currentPageIndex = index;
        const currentPage = journalPages[index];
        const feature = currentPage.getAttribute('data-feature');
        
        currentPage.classList.add('active');
        
        // Update feature content
        const correspondingContent = document.querySelector(`.feature-content[data-feature="${feature}"]`);
        if (correspondingContent) {
            correspondingContent.classList.add('active');
        }
        console.log('Navigated to:', feature, 'Index:', index, 'Content found:', !!correspondingContent);
        
        // Update background sketch
        const correspondingSketch = document.querySelector(`.sketch-layer[data-feature="${feature}"]`);
        if (correspondingSketch) {
            correspondingSketch.classList.add('active-sketch');
        }
        
        updateNavButtons();
    }
    
    // Navigation button handlers
    prevButton.addEventListener('click', () => {
        navigateToPage(currentPageIndex - 1);
    });
    
    nextButton.addEventListener('click', () => {
        navigateToPage(currentPageIndex + 1);
    });
    
    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') {
            navigateToPage(currentPageIndex - 1);
        } else if (e.key === 'ArrowRight') {
            navigateToPage(currentPageIndex + 1);
        }
    });
    
    journalPages.forEach((page, index) => {
        const feature = page.getAttribute('data-feature');
        
        page.addEventListener('mouseenter', function() {
            const correspondingSketch = document.querySelector(`.sketch-layer[data-feature="${feature}"]`);
            if (correspondingSketch) {
                correspondingSketch.classList.add('highlighted');
            }
        });
        
        page.addEventListener('mouseleave', function() {
            const correspondingSketch = document.querySelector(`.sketch-layer[data-feature="${feature}"]`);
            if (correspondingSketch) {
                correspondingSketch.classList.remove('highlighted');
            }
        });
        
        // Handle click to navigate
        page.addEventListener('click', function(e) {
            e.preventDefault();
            navigateToPage(index);
            // Ensure the page doesn't steal focus from keyboard navigation
            this.blur();
        });
    });
    
    // Initialize first page as active
    navigateToPage(0);
    
    // Randomize annotation positions on page load
    randomizeAnnotations();
});

function randomizeAnnotations() {
    const annotations = document.querySelectorAll('.annotations');
    
    annotations.forEach(container => {
        const topRight = container.querySelector('.annotation.top-right');
        const bottomLeft = container.querySelector('.annotation.bottom-left');
        
        if (topRight) {
            // Randomize top-right annotation position
            const positions = [
                { top: '20px', right: '20px' },
                { top: '30px', right: '35px' },
                { top: '40px', right: '25px' },
                { top: '25px', right: '45px' },
                { top: '35px', right: '30px' },
                { top: '45px', right: '40px' },
                { top: '15px', right: '30px' },
                { top: '50px', right: '20px' }
            ];
            const randomPos = positions[Math.floor(Math.random() * positions.length)];
            topRight.style.top = randomPos.top;
            topRight.style.right = randomPos.right;
            
            // Add slight rotation
            const rotation = Math.random() * 10 - 5; // -5 to 5 degrees
            topRight.style.transform = `rotate(${rotation}deg)`;
        }
        
        if (bottomLeft) {
            // Randomize bottom-left annotation position
            const positions = [
                { bottom: '25px', left: '20px' },
                { bottom: '35px', left: '30px' },
                { bottom: '30px', left: '25px' },
                { bottom: '40px', left: '35px' },
                { bottom: '20px', left: '40px' },
                { bottom: '45px', left: '25px' },
                { bottom: '35px', left: '45px' },
                { bottom: '30px', left: '15px' }
            ];
            const randomPos = positions[Math.floor(Math.random() * positions.length)];
            bottomLeft.style.bottom = randomPos.bottom;
            bottomLeft.style.left = randomPos.left;
            
            // Add slight rotation
            const rotation = Math.random() * 10 - 5; // -5 to 5 degrees
            bottomLeft.style.transform = `rotate(${rotation}deg)`;
        }
    });
    
    // Also randomize math annotations positions
    const mathAnnotations = document.querySelectorAll('.math-annotations');
    mathAnnotations.forEach(mathContainer => {
        // Add random offset to pseudo-elements by injecting a style
        const offsetX = Math.random() * 20 - 10; // -10 to 10 pixels
        const offsetY = Math.random() * 20 - 10; // -10 to 10 pixels
        mathContainer.style.setProperty('--math-offset-x', `${offsetX}px`);
        mathContainer.style.setProperty('--math-offset-y', `${offsetY}px`);
    });
}
</script>
{% endblock %}