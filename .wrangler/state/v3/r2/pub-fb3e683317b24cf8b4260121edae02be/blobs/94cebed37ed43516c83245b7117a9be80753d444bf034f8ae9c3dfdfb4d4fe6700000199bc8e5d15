<svg viewBox="0 0 1200 800" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <style>
      .scenario-title { font-family: 'Georgia', serif; font-size: 28px; font-weight: bold; fill: #2d3c34; }
      .scenario-subtitle { font-family: 'Georgia', serif; font-size: 16px; fill: #5a6b5f; font-style: italic; }
      .scenario-label { font-family: 'Arial', sans-serif; font-size: 14px; font-weight: 600; fill: #2d3c34; }
      .scenario-value { font-family: 'Arial', sans-serif; font-size: 13px; fill: #4a5a4f; }
      .scenario-total { font-family: 'Arial', sans-serif; font-size: 18px; font-weight: bold; fill: #ffffff; }
      .scenario-monthly { font-family: 'Arial', sans-serif; font-size: 22px; font-weight: bold; }
      .section-header { font-family: 'Arial', sans-serif; font-size: 12px; font-weight: 600; fill: #666; text-transform: uppercase; letter-spacing: 1px; }
    </style>
    <!-- Gradient definitions -->
    <linearGradient id="grad-conservative" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#8b7659;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#6b5639;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="grad-moderate" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#5a9fd4;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#3a7fb4;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="grad-progressive" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#6ea84f;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#4e882f;stop-opacity:1" />
    </linearGradient>
  </defs>

  <!-- Title -->
  <text x="600" y="40" text-anchor="middle" class="scenario-title">Three Pathways to Universal Basic Income by 2035</text>
  <text x="600" y="65" text-anchor="middle" class="scenario-subtitle">Flexible funding scenarios based on political feasibility</text>

  <!-- Scenario A: Conservative -->
  <g id="scenario-a">
    <rect x="30" y="100" width="350" height="660" rx="12" fill="#f8f6f3" stroke="#8b7659" stroke-width="2"/>
    <rect x="30" y="100" width="350" height="50" rx="12" fill="url(#grad-conservative)"/>
    <text x="205" y="133" text-anchor="middle" class="scenario-total">Scenario A: Conservative</text>

    <!-- Defense Reduction -->
    <text x="50" y="180" class="section-header">Defense Restructuring</text>
    <text x="50" y="200" class="scenario-label">• Modest 15% reduction</text>
    <text x="70" y="218" class="scenario-value">Annual Savings: $315B</text>

    <!-- Other Funding -->
    <text x="50" y="250" class="section-header">Other Government Savings</text>
    <text x="50" y="270" class="scenario-label">• Bureaucracy reduction (30%)</text>
    <text x="70" y="288" class="scenario-value">Savings: $225B</text>
    <text x="50" y="308" class="scenario-label">• Welfare consolidation</text>
    <text x="70" y="326" class="scenario-value">Savings: $600B</text>

    <!-- Technology -->
    <text x="50" y="358" class="section-header">Technology Cost Reductions</text>
    <text x="50" y="378" class="scenario-label">• Fusion energy (early adoption)</text>
    <text x="70" y="396" class="scenario-value">Value: $200-300/month/person</text>
    <text x="50" y="416" class="scenario-label">• Solar + gravity storage</text>
    <text x="70" y="434" class="scenario-value">Value: $100-150/month/person</text>

    <!-- Solarpunk -->
    <text x="50" y="466" class="section-header">Solarpunk Living Reductions</text>
    <text x="50" y="486" class="scenario-label">• Robotic food production</text>
    <text x="70" y="504" class="scenario-value">Savings: $150-200/month</text>
    <text x="50" y="524" class="scenario-label">• Off-grid/closed-loop</text>
    <text x="70" y="542" class="scenario-value">Savings: $200-350/month</text>
    <text x="50" y="562" class="scenario-label">• Robot housing (5% adoption)</text>
    <text x="70" y="580" class="scenario-value">Reduced: $100-150/month</text>

    <!-- Crypto -->
    <text x="50" y="612" class="section-header">Cryptocurrency Revenue</text>
    <text x="50" y="632" class="scenario-label">• Bitcoin reserve (conservative)</text>
    <text x="70" y="650" class="scenario-value">Annual: $200B</text>
    <text x="50" y="670" class="scenario-label">• Proof-of-useful-work</text>
    <text x="70" y="688" class="scenario-value">Annual: $150B</text>

    <!-- Total -->
    <rect x="50" y="710" width="310" height="35" rx="6" fill="#8b7659"/>
    <text x="205" y="733" text-anchor="middle" class="scenario-total">Monthly UBI: $600-800</text>
  </g>

  <!-- Scenario B: Moderate -->
  <g id="scenario-b">
    <rect x="425" y="100" width="350" height="660" rx="12" fill="#f3f8fc" stroke="#5a9fd4" stroke-width="2"/>
    <rect x="425" y="100" width="350" height="50" rx="12" fill="url(#grad-moderate)"/>
    <text x="600" y="133" text-anchor="middle" class="scenario-total">Scenario B: Moderate</text>

    <!-- Defense Reduction -->
    <text x="445" y="180" class="section-header">Defense Restructuring</text>
    <text x="445" y="200" class="scenario-label">• Balanced 40% reduction</text>
    <text x="465" y="218" class="scenario-value">Annual Savings: $840B</text>

    <!-- Other Funding -->
    <text x="445" y="250" class="section-header">Other Government Savings</text>
    <text x="445" y="270" class="scenario-label">• Bureaucracy reduction (45%)</text>
    <text x="465" y="288" class="scenario-value">Savings: $385B</text>
    <text x="445" y="308" class="scenario-label">• Welfare consolidation</text>
    <text x="465" y="326" class="scenario-value">Savings: $600B</text>

    <!-- Technology -->
    <text x="445" y="358" class="section-header">Technology Cost Reductions</text>
    <text x="445" y="378" class="scenario-label">• Fusion energy (wide adoption)</text>
    <text x="465" y="396" class="scenario-value">Value: $350-450/month/person</text>
    <text x="445" y="416" class="scenario-label">• Solar + gravity + geothermal</text>
    <text x="465" y="434" class="scenario-value">Value: $150-250/month/person</text>

    <!-- Solarpunk -->
    <text x="445" y="466" class="section-header">Solarpunk Living Reductions</text>
    <text x="445" y="486" class="scenario-label">• Robotic food production</text>
    <text x="465" y="504" class="scenario-value">Savings: $250-350/month</text>
    <text x="445" y="524" class="scenario-label">• Off-grid/closed-loop</text>
    <text x="465" y="542" class="scenario-value">Savings: $300-450/month</text>
    <text x="445" y="562" class="scenario-label">• Robot housing (25% adoption)</text>
    <text x="465" y="580" class="scenario-value">Reduced: $200-300/month</text>

    <!-- Crypto -->
    <text x="445" y="612" class="section-header">Cryptocurrency Revenue</text>
    <text x="445" y="632" class="scenario-label">• Bitcoin reserve (moderate)</text>
    <text x="465" y="650" class="scenario-value">Annual: $800B</text>
    <text x="445" y="670" class="scenario-label">• Proof-of-useful-work</text>
    <text x="465" y="688" class="scenario-value">Annual: $350B</text>

    <!-- Total -->
    <rect x="445" y="710" width="310" height="35" rx="6" fill="#5a9fd4"/>
    <text x="600" y="733" text-anchor="middle" class="scenario-total">Monthly UBI: $1,200-1,500</text>
  </g>

  <!-- Scenario C: Progressive -->
  <g id="scenario-c">
    <rect x="820" y="100" width="350" height="660" rx="12" fill="#f3f9f0" stroke="#6ea84f" stroke-width="2"/>
    <rect x="820" y="100" width="350" height="50" rx="12" fill="url(#grad-progressive)"/>
    <text x="995" y="133" text-anchor="middle" class="scenario-total">Scenario C: Progressive</text>

    <!-- Defense Reduction -->
    <text x="840" y="180" class="section-header">Defense Restructuring</text>
    <text x="840" y="200" class="scenario-label">• Bold 70% reduction</text>
    <text x="860" y="218" class="scenario-value">Annual Savings: $1.47T</text>

    <!-- Other Funding -->
    <text x="840" y="250" class="section-header">Other Government Savings</text>
    <text x="840" y="270" class="scenario-label">• Bureaucracy reduction (55%)</text>
    <text x="860" y="288" class="scenario-value">Savings: $475B</text>
    <text x="840" y="308" class="scenario-label">• Welfare consolidation</text>
    <text x="860" y="326" class="scenario-value">Savings: $600B</text>

    <!-- Technology -->
    <text x="840" y="358" class="section-header">Technology Cost Reductions</text>
    <text x="840" y="378" class="scenario-label">• Fusion energy (universal)</text>
    <text x="860" y="396" class="scenario-value">Value: $500-700/month/person</text>
    <text x="840" y="416" class="scenario-label">• Full renewable integration</text>
    <text x="860" y="434" class="scenario-value">Value: $250-400/month/person</text>

    <!-- Solarpunk -->
    <text x="840" y="466" class="section-header">Solarpunk Living Reductions</text>
    <text x="840" y="486" class="scenario-label">• Robotic food production</text>
    <text x="860" y="504" class="scenario-value">Savings: $350-450/month</text>
    <text x="840" y="524" class="scenario-label">• Off-grid/closed-loop</text>
    <text x="860" y="542" class="scenario-value">Savings: $400-500/month</text>
    <text x="840" y="562" class="scenario-label">• Robot housing (50% adoption)</text>
    <text x="860" y="580" class="scenario-value">Reduced: $300-450/month</text>

    <!-- Crypto -->
    <text x="840" y="612" class="section-header">Cryptocurrency Revenue</text>
    <text x="840" y="632" class="scenario-label">• Bitcoin reserve (bull case)</text>
    <text x="860" y="650" class="scenario-value">Annual: $1.5T-2T</text>
    <text x="840" y="670" class="scenario-label">• Proof-of-useful-work</text>
    <text x="860" y="688" class="scenario-value">Annual: $500B</text>

    <!-- Total -->
    <rect x="840" y="710" width="310" height="35" rx="6" fill="#6ea84f"/>
    <text x="995" y="733" text-anchor="middle" class="scenario-total">Monthly UBI: $2,000-2,600</text>
  </g>

  <!-- Note at bottom -->
  <text x="600" y="785" text-anchor="middle" style="font-size: 11px; fill: #666; font-style: italic;">
    All scenarios include cost-of-living reductions that provide $750-1,900/month additional value through technology and sustainable living practices.
  </text>
</svg>